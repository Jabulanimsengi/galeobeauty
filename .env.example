BOOKINGS_ADMIN_PASSWORD=replace-with-a-long-random-password
DATABASE_URL=postgres://user:password@host:5432/database
GALEO_HEALTH_TOKEN=replace-with-a-long-random-token
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-browser-key
# Leave both Turnstile values blank only if you intentionally want booking CAPTCHA disabled in production.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your-cloudflare-turnstile-site-key
TURNSTILE_SECRET_KEY=your-cloudflare-turnstile-secret-key
