BOOKINGS_ADMIN_PASSWORD=replace-with-a-long-random-password
DATABASE_URL=postgres://user:password@host:5432/database
GALEO_HEALTH_TOKEN=replace-with-a-long-random-token
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-browser-key
NEXT_PUBLIC_SITE_URL=https://www.galeobeauty.com
PAYFAST_MERCHANT_ID=your-payfast-merchant-id
PAYFAST_MERCHANT_KEY=your-payfast-merchant-key
PAYFAST_PASSPHRASE=your-payfast-passphrase
NEXT_PUBLIC_PAYFAST_SANDBOX=true
# Leave both Turnstile values blank only if you intentionally want booking CAPTCHA disabled in production.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your-cloudflare-turnstile-site-key
TURNSTILE_SECRET_KEY=your-cloudflare-turnstile-secret-key
RESEND_API_KEY=your-resend-api-key
RESEND_FROM_EMAIL=Galeo Beauty <bookings@galeobeauty.com>
RESEND_REPLY_TO_EMAIL=info@galeobeauty.com
CHATBOT_LEADS_TO_EMAIL=info@galeobeauty.com
GALEO_BOOKING_FEE_PERCENTAGE=50
OPENAI_API_KEY=your-openai-api-key
OPENAI_CHAT_MODEL=gpt-5-mini
