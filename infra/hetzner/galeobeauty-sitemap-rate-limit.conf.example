map $galeo_upstream $galeo_public_root {
    default /var/www/galeobeauty-blue/public;
    http://127.0.0.1:3000 /var/www/galeobeauty-blue/public;
    http://127.0.0.1:3001 /var/www/galeobeauty-green/public;
}

limit_req_zone $binary_remote_addr zone=galeo_sitemap:10m rate=2r/s;
limit_req_zone $binary_remote_addr zone=galeo_admin_login:10m rate=5r/m;
limit_req_zone $binary_remote_addr zone=galeo_admin_area:10m rate=60r/m;
limit_req_zone $binary_remote_addr zone=galeo_booking_api:10m rate=20r/m;
